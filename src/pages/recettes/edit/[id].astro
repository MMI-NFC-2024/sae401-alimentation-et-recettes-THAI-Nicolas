---
import ProtectedLayout from "../../../layouts/ProtectedLayout.astro";
import DamierHero from "../../../components/ui/DamierHero.astro";
import RecetteEditIngredientsEtapes from "../../../components/ui/RecetteEditIngredientsEtapes.vue";
import { actions, isInputError } from "astro:actions";
import { getCompositionByRecetteId } from "../../../lib/services/composition.service";
import { getEtapesByRecetteId } from "../../../lib/services/etapes.service";
import { getAllIngredients } from "../../../lib/services/ingredients.service";
import { getRegimeOptions } from "../../../lib/services/regimes.service";

const { id } = Astro.params as { id?: string };

if (!id) {
  return Astro.redirect("/404");
}

const updateRecetteResult = Astro.getActionResult(actions.updateRecette);

if (updateRecetteResult?.data?.success && updateRecetteResult.data.redirectTo) {
  return Astro.redirect(updateRecetteResult.data.redirectTo);
}

const updateRecetteInputError = isInputError(updateRecetteResult?.error)
  ? updateRecetteResult.error
  : undefined;

const updateRecetteGlobalError =
  updateRecetteResult?.error && !isInputError(updateRecetteResult.error)
    ? updateRecetteResult.error.message
    : undefined;
const hasFormError = Boolean(
  updateRecetteGlobalError || updateRecetteInputError,
);

const editSuccess =
  Astro.url.searchParams.get("recette") === "updated"
    ? "Recette mise a jour avec succes."
    : undefined;

const isAuthenticated = Astro.locals.pb?.authStore?.isValid ?? false;
if (!isAuthenticated) {
  return Astro.redirect(
    `/auth/login?returnTo=${encodeURIComponent(Astro.url.pathname)}`,
  );
}

const authModel = Astro.locals.pb?.authStore?.model as { id?: string } | null;
const currentUserId = authModel?.id;

if (!currentUserId) {
  return Astro.redirect(
    `/auth/login?returnTo=${encodeURIComponent(Astro.url.pathname)}`,
  );
}

let recette: any;

try {
  recette = await Astro.locals.pb.collection("recettes").getOne(id);
} catch {
  return Astro.redirect("/404");
}

if (recette.user !== currentUserId) {
  return Astro.redirect("/404");
}

const [
  compositionResult,
  etapesResult,
  ingredientsResult,
  regimeOptionsResult,
] = await Promise.all([
  getCompositionByRecetteId(Astro.locals.pb, recette.id),
  getEtapesByRecetteId(Astro.locals.pb, recette.id),
  getAllIngredients(Astro.locals.pb),
  getRegimeOptions(Astro.locals.pb),
]);

const composition = compositionResult.data;
const etapes = etapesResult.data;
const ingredients = ingredientsResult.data;
const regimeOptions = regimeOptionsResult.data;

const initialComposition = composition.map((item) => ({
  ingredientId: item.expand?.ingredient?.id ?? item.ingredient,
  nom: item.expand?.ingredient?.nom ?? "Ingredient",
  categorie: item.expand?.ingredient?.categorie ?? "Autres",
  quantite: item.quantite ?? 0,
  unite: item.unite ?? "",
}));

const initialEtapes = etapes
  .sort((a, b) => Number(a.numero_ordre ?? 0) - Number(b.numero_ordre ?? 0))
  .map((item) => ({
    titre: item.titre ?? "",
    description: item.description ?? "",
  }));

const ingredientsLite = ingredients.map((item) => ({
  id: item.id,
  nom: item.nom ?? "Ingredient",
  categorie: item.categorie ?? "Autres",
}));

const returnTo = `/profil/${currentUserId}`;
---

<ProtectedLayout>
  <section class="p-0">
    <header>
      <DamierHero title="Modifier une recette" />
    </header>
  </section>

  <section class="section content-container pt-10!">
    <div class="mx-auto max-w-5xl space-y-6">
      {
        editSuccess && (
          <p class="rounded-xl border-2 border-primary bg-primary/10 px-4 py-3 text-sm font-bold text-primary">
            {editSuccess}
          </p>
        )
      }

      {
        updateRecetteGlobalError && (
          <p class="rounded-xl border-2 border-accent2 bg-accent2/10 px-4 py-3 text-sm font-bold text-accent2">
            {updateRecetteGlobalError}
          </p>
        )
      }

      <form
        id="edit-recette-form"
        data-has-error={hasFormError ? "true" : "false"}
        method="post"
        action={actions.updateRecette}
        enctype="multipart/form-data"
        class="flex flex-col gap-8 lg:gap-16"
      >
        <input
          type="hidden"
          name="recetteId"
          value={recette.id}
          data-persist="true"
        />
        <input
          type="hidden"
          name="returnTo"
          value={returnTo}
          data-persist="true"
        />
        <input
          type="hidden"
          name="compositionJson"
          id="compositionJson"
          data-persist="true"
        />
        <input
          type="hidden"
          name="etapesJson"
          id="etapesJson"
          data-persist="true"
        />

        <article
          class="rounded-2xl border-2 border-primary bg-secondary p-5 shadow-[0_4px_0_0_var(--color-primary)]"
        >
          <h2 class="mb-5">Informations recette</h2>

          <div class="grid gap-5 md:grid-cols-2">
            <div class="md:col-span-2">
              <label class="label" for="titre">Titre</label>
              <input
                id="titre"
                name="titre"
                class="input mt-2"
                value={recette.titre ?? ""}
                required
                data-persist="true"
              />
              {
                updateRecetteInputError?.fields.titre?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {updateRecetteInputError.fields.titre[0]}
                  </p>
                )
              }
            </div>

            <div>
              <label class="label" for="categorie">Categorie</label>
              <select
                id="categorie"
                name="categorie"
                class="input mt-2 cursor-pointer"
                required
                data-persist="true"
              >
                <option value="Entrée" selected={recette.categorie === "Entrée"}
                  >Entrée</option
                >
                <option value="Plat" selected={recette.categorie === "Plat"}
                  >Plat</option
                >
                <option
                  value="Dessert"
                  selected={recette.categorie === "Dessert"}>Dessert</option
                >
                <option
                  value="Boisson"
                  selected={recette.categorie === "Boisson"}>Boisson</option
                >
              </select>
              {
                updateRecetteInputError?.fields.categorie?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {updateRecetteInputError.fields.categorie[0]}
                  </p>
                )
              }
            </div>

            <div>
              <label class="label" for="objectif_sante">Objectif sante</label>
              <select
                id="objectif_sante"
                name="objectif_sante"
                class="input mt-2 cursor-pointer"
                required
                data-persist="true"
              >
                <option
                  value="Prise de masse"
                  selected={recette.objectif_sante === "Prise de masse"}
                  >Prise de masse</option
                >
                <option
                  value="Perte de poids"
                  selected={recette.objectif_sante === "Perte de poids"}
                  >Perte de poids</option
                >
                <option
                  value="Équilibre"
                  selected={recette.objectif_sante === "Équilibre"}
                  >Équilibre</option
                >
              </select>
              {
                updateRecetteInputError?.fields.objectif_sante?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {updateRecetteInputError.fields.objectif_sante[0]}
                  </p>
                )
              }
            </div>

            <div class="md:col-span-2">
              <p class="label">Regimes</p>
              <div class="mt-3 grid gap-3 sm:grid-cols-2">
                <input type="hidden" name="regimes" value="" />
                {
                  regimeOptions.map((regime) => (
                    <label class="inline-flex items-center gap-2 text-sm font-afacad uppercase cursor-pointer">
                      <input
                        type="checkbox"
                        name="regimes"
                        value={regime.id}
                        checked={(recette.regimes ?? []).includes(regime.id)}
                        class="h-4 w-4 appearance-none rounded-sm border-2 border-primary bg-secondary checked:bg-primary cursor-pointer"
                        data-persist="true"
                      />
                      {regime.name}
                    </label>
                  ))
                }
              </div>
              {
                updateRecetteInputError?.fields.regimes?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {updateRecetteInputError.fields.regimes[0]}
                  </p>
                )
              }
            </div>

            <div>
              <label class="label" for="temps_total">Temps total (min)</label>
              <input
                id="temps_total"
                name="temps_total"
                type="number"
                min="1"
                class="input mt-2"
                value={recette.temps_total ?? 1}
                required
                data-persist="true"
              />
              {
                updateRecetteInputError?.fields.temps_total?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {updateRecetteInputError.fields.temps_total[0]}
                  </p>
                )
              }
            </div>

            <div>
              <label class="label" for="portions">Portions</label>
              <input
                id="portions"
                name="portions"
                type="number"
                min="1"
                class="input mt-2"
                value={recette.portions ?? 1}
                required
                data-persist="true"
              />
              {
                updateRecetteInputError?.fields.portions?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {updateRecetteInputError.fields.portions[0]}
                  </p>
                )
              }
            </div>

            <div>
              <label class="label" for="kcal_portion">Kcal / portion</label>
              <input
                id="kcal_portion"
                name="kcal_portion"
                type="number"
                min="0"
                step="0.1"
                class="input mt-2"
                value={recette.kcal_portion ?? 0}
                required
                data-persist="true"
              />
              {
                updateRecetteInputError?.fields.kcal_portion?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {updateRecetteInputError.fields.kcal_portion[0]}
                  </p>
                )
              }
            </div>

            <div>
              <label class="label" for="total_proteines"
                >Total proteines (g)</label
              >
              <input
                id="total_proteines"
                name="total_proteines"
                type="number"
                min="0"
                step="0.1"
                class="input mt-2"
                value={recette.total_proteines ?? 0}
                required
                data-persist="true"
              />
              {
                updateRecetteInputError?.fields.total_proteines?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {updateRecetteInputError.fields.total_proteines[0]}
                  </p>
                )
              }
            </div>

            <div>
              <label class="label" for="total_glucides"
                >Total glucides (g)</label
              >
              <input
                id="total_glucides"
                name="total_glucides"
                type="number"
                min="0"
                step="0.1"
                class="input mt-2"
                value={recette.total_glucides ?? 0}
                required
                data-persist="true"
              />
              {
                updateRecetteInputError?.fields.total_glucides?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {updateRecetteInputError.fields.total_glucides[0]}
                  </p>
                )
              }
            </div>

            <div>
              <label class="label" for="total_lipides">Total lipides (g)</label>
              <input
                id="total_lipides"
                name="total_lipides"
                type="number"
                min="0"
                step="0.1"
                class="input mt-2"
                value={recette.total_lipides ?? 0}
                required
                data-persist="true"
              />
              {
                updateRecetteInputError?.fields.total_lipides?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {updateRecetteInputError.fields.total_lipides[0]}
                  </p>
                )
              }
            </div>

            <div>
              <label class="label" for="image">Nouvelle image (optionnel)</label
              >
              <input
                id="image"
                type="file"
                name="image"
                class="mt-2 block w-full rounded-2xl border-2 border-primary bg-secondary px-4 py-3 text-sm text-primary cursor-pointer"
                accept="image/*"
              />
              <p class="mt-2 text-xs text-primary/70">
                Laisser vide pour conserver l'image actuelle.
              </p>
              <p class="mt-1 text-xs text-primary/70">Taille maximale: 5 Mo.</p>
              {
                updateRecetteInputError?.fields.image?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {updateRecetteInputError.fields.image[0]}
                  </p>
                )
              }
            </div>

            <div class="md:col-span-2">
              <label class="label" for="description">Description</label>
              <textarea
                id="description"
                name="description"
                class="mt-2 w-full rounded-2xl border-2 border-primary bg-secondary px-4 py-3 text-primary outline-none"
                rows={6}
                data-persist="true">{recette.description ?? ""}</textarea
              >
            </div>
          </div>
        </article>

        {
          (updateRecetteInputError?.fields.compositionJson?.[0] ||
            updateRecetteInputError?.fields.etapesJson?.[0]) && (
            <p class="rounded-xl border-2 border-accent2 bg-accent2/10 px-4 py-3 text-sm font-bold text-accent2">
              {updateRecetteInputError?.fields.compositionJson?.[0] ??
                updateRecetteInputError?.fields.etapesJson?.[0]}
            </p>
          )
        }

        <RecetteEditIngredientsEtapes
          client:load
          ingredients={ingredientsLite}
          initialComposition={initialComposition}
          initialEtapes={initialEtapes}
          compositionInputId="compositionJson"
          etapesInputId="etapesJson"
        />

        <div class="flex items-center justify-between gap-3">
          <a href="/profil" class="btn-outline">Annuler</a>
          <button type="submit" class="btn">Mettre a jour</button>
        </div>
      </form>
    </div>
  </section>
</ProtectedLayout>

<script is:inline>
  (() => {
    const storageKey = `slurpy:recette:edit:draft:${window.location.pathname}`;
    const maxImageSizeBytes = 5 * 1024 * 1024;
    const maxImageSizeMessage = "L'image est trop lourde (max 5 Mo).";
    const form = document.getElementById("edit-recette-form");
    const imageInput = document.getElementById("image");

    if (!(form instanceof HTMLFormElement)) return;

    const validateImageSize = () => {
      if (!(imageInput instanceof HTMLInputElement)) {
        return true;
      }

      const selectedFile = imageInput.files?.[0];

      if (!selectedFile) {
        imageInput.setCustomValidity("");
        return true;
      }

      const isValidSize = selectedFile.size <= maxImageSizeBytes;
      imageInput.setCustomValidity(isValidSize ? "" : maxImageSizeMessage);
      return isValidSize;
    };

    if (imageInput instanceof HTMLInputElement) {
      imageInput.addEventListener("change", () => {
        validateImageSize();
        imageInput.reportValidity();
      });
    }

    const shouldRestoreDraft = form.dataset.hasError === "true";
    const fields = Array.from(form.querySelectorAll("[data-persist='true']"));

    if (!shouldRestoreDraft) {
      sessionStorage.removeItem(storageKey);
    }

    let draft = {};
    try {
      draft = JSON.parse(sessionStorage.getItem(storageKey) ?? "{}");
    } catch {
      draft = {};
    }

    if (shouldRestoreDraft) {
      for (const field of fields) {
        if (
          !(field instanceof HTMLInputElement) &&
          !(field instanceof HTMLTextAreaElement) &&
          !(field instanceof HTMLSelectElement)
        ) {
          continue;
        }

        const fieldName = field.getAttribute("name");
        if (!fieldName) continue;

        if (field instanceof HTMLInputElement && field.type === "file") {
          continue;
        }

        const draftValue = draft[fieldName];

        if (field instanceof HTMLInputElement && field.type === "checkbox") {
          if (Array.isArray(draftValue)) {
            field.checked = draftValue.includes(field.value);
          }
          continue;
        }

        if (typeof draftValue === "string") {
          field.value = draftValue;
        }
      }
    }

    const saveDraft = () => {
      const nextDraft = {};

      for (const field of fields) {
        if (
          !(field instanceof HTMLInputElement) &&
          !(field instanceof HTMLTextAreaElement) &&
          !(field instanceof HTMLSelectElement)
        ) {
          continue;
        }

        const fieldName = field.getAttribute("name");
        if (!fieldName) continue;

        if (field instanceof HTMLInputElement && field.type === "file") {
          continue;
        }

        if (field instanceof HTMLInputElement && field.type === "checkbox") {
          if (!Array.isArray(nextDraft[fieldName])) {
            nextDraft[fieldName] = [];
          }

          if (field.checked) {
            nextDraft[fieldName].push(field.value);
          }
          continue;
        }

        nextDraft[fieldName] = field.value;
      }

      sessionStorage.setItem(storageKey, JSON.stringify(nextDraft));
    };

    for (const field of fields) {
      field.addEventListener("input", saveDraft);
      field.addEventListener("change", saveDraft);
    }

    form.addEventListener("submit", (event) => {
      if (!validateImageSize()) {
        event.preventDefault();
        if (imageInput instanceof HTMLInputElement) {
          imageInput.reportValidity();
        }
        return;
      }

      saveDraft();
    });
  })();
</script>
