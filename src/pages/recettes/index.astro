---
import DamierHero from "../../components/ui/DamierHero.astro";
import Layout from "../../layouts/Layout.astro";
import { getAllRecettes } from "../../lib/services/recettes.service";
import { getRegimeOptions } from "../../lib/services/regimes.service";
import { getAvisStatsByRecetteIds } from "../../lib/services/avis.service";
import CardRecette from "../../components/ui/CardRecette.astro";
import RecettesFiltersPanel from "../../components/ui/RecettesFiltersPanel.vue";

// Récupérer toutes les recettes pour les afficher sur la page d'accueil
const { data: recettes, error: recettesError } = await getAllRecettes(
  Astro.locals.pb,
);

// Récupérer toutes les options de régimes 
const { data: regimeOptions } = await getRegimeOptions(Astro.locals.pb);

// Récupération de tous les avis pour les recettes affichées
const { data: avisStatsByRecette } = await getAvisStatsByRecetteIds(
  Astro.locals.pb,
  recettes.map((recette) => recette.id),
);
---

<Layout>
  <section class="p-0">
    <header>
      <DamierHero title="Nos recettes" />
    </header>
  </section>
  <section class="section content-container pt-10!">
    <div
      class="grid grid-cols-1 gap-10 lg:grid-cols-[260px_minmax(0,1fr)] lg:items-start lg:gap-10"
    >
      <div class="lg:sticky lg:top-28 lg:self-start">
        <RecettesFiltersPanel client:load regimes={regimeOptions} />
      </div>

      <div>
        <div class="mb-8 flex justify-center lg:justify-end">
          <a href="/recettes/add" class="btn bg-accent1!">
            + Ajouter ma recette
          </a>
        </div>

        {
          recettes.length > 0 ? (
            <div>
              <ul
                class="grid grid-cols-1 gap-7 md:grid-cols-2 lg:grid-cols-3"
                data-recettes-grid
              >
                {recettes.map((recette) => {
                  const avisStats = avisStatsByRecette[recette.id] ?? {
                    average: 0,
                    total: 0,
                  };

                  return (
                    <li
                      data-recette-item
                      data-title={recette.titre}
                      data-objectif={recette.objectif_sante}
                      data-categorie={recette.categorie}
                      data-regimes={(recette.regimes ?? []).join(",")}
                      data-rating={String(avisStats.average)}
                    >
                      <CardRecette
                        recette={recette}
                        rating={avisStats.average}
                        reviewsCount={avisStats.total}
                      />
                    </li>
                  );
                })}
              </ul>

              <div
                id="recettes-pagination"
                class="mt-10 flex items-center justify-center"
              />
              <p id="recettes-empty" class="mt-8 text-center" hidden />
            </div>
          ) : (
            <p class="mt-8 text-center">
              {recettesError
                ? "Les recettes sont temporairement indisponibles. Reessaie dans quelques instants."
                : "Aucune recette trouvée."}
            </p>
          )
        }
      </div>
    </div>
  </section>
</Layout>
