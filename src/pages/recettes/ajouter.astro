---
import ProtectedLayout from "../../layouts/ProtectedLayout.astro";
import DamierHero from "../../components/ui/DamierHero.astro";
---

<ProtectedLayout>
  <section class="p-0">
    <header>
      <DamierHero title="Ajouter une recette" />
    </header>
  </section>

  <section class="section content-container pt-10!">
    <div class="max-w-3xl space-y-5">
      <p class="text-base text-primary/90">
        Cette page dediee a la creation de recette est prete.
      </p>
      <p class="text-base text-primary/90">
        On y branchera le formulaire complet (infos, ingredients, etapes) dans la prochaine iteration.
      </p>
      <a href="/profil" class="btn">Retour au profil</a>
    </div>
  </section>
</ProtectedLayout>
