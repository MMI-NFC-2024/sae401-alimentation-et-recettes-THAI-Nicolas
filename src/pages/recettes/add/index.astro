---
import ProtectedLayout from "../../../layouts/ProtectedLayout.astro";
import DamierHero from "../../../components/ui/DamierHero.astro";
import RecetteEditIngredientsEtapes from "../../../components/ui/RecetteEditIngredientsEtapes.vue";
import { actions, isInputError } from "astro:actions";
import { getAllIngredients } from "../../../lib/services/ingredients.service";
import { getRegimeOptions } from "../../../lib/services/regimes.service";

// Lit le resultat d'action createRecette pour gerer redirection et messages d'erreur
const createRecetteResult = Astro.getActionResult(actions.createRecette);

if (createRecetteResult?.data?.success && createRecetteResult.data.redirectTo) {
  return Astro.redirect(createRecetteResult.data.redirectTo);
}

// Separe erreurs de champs (input) et erreurs globales (server) pour l'affichage du formulaire
const createRecetteInputError = isInputError(createRecetteResult?.error)
  ? createRecetteResult.error
  : undefined;

const createRecetteGlobalError =
  createRecetteResult?.error && !isInputError(createRecetteResult.error)
    ? createRecetteResult.error.message
    : undefined;
const hasFormError = Boolean(
  createRecetteGlobalError || createRecetteInputError,
);

// Verifie l'authentification avant de donner l'accès à l'ajout d'une recette
const isAuthenticated = Astro.locals.pb?.authStore?.isValid ?? false;
if (!isAuthenticated) {
  return Astro.redirect(
    `/auth/login?returnTo=${encodeURIComponent(Astro.url.pathname)}`,
  );
}

// Charge les referentiels utilises par le formulaire (ingredients + regimes)
const { data: ingredients } = await getAllIngredients(Astro.locals.pb);
const { data: regimeOptions } = await getRegimeOptions(Astro.locals.pb);

// Reduit les ingredients au format minimal requis par le composant dynamique.
const ingredientsLite = ingredients.map((item) => ({
  id: item.id,
  nom: item.nom ?? "Ingredient",
  categorie: item.categorie ?? "Autres",
}));
---

<ProtectedLayout>
  <section class="p-0">
    <header>
      <DamierHero title="Ajouter une recette" />
    </header>
  </section>

  <section class="section content-container pt-10!">
    <div class="mx-auto max-w-5xl space-y-6">
      {
        createRecetteGlobalError && (
          <p class="rounded-xl border-2 border-accent2 bg-accent2/10 px-4 py-3 text-sm font-bold text-accent2">
            {createRecetteGlobalError}
          </p>
        )
      }

      <form
        id="add-recette-form"
        data-has-error={hasFormError ? "true" : "false"}
        method="post"
        action={actions.createRecette}
        enctype="multipart/form-data"
        class="flex flex-col gap-8 lg:gap-16"
      >
        <input
          type="hidden"
          name="returnTo"
          value="/profil"
          data-persist="true"
        />
        <input
          type="hidden"
          name="compositionJson"
          id="compositionJson"
          data-persist="true"
        />
        <input
          type="hidden"
          name="etapesJson"
          id="etapesJson"
          data-persist="true"
        />

        <article
          class="rounded-2xl border-2 border-primary bg-secondary p-5 shadow-[0_4px_0_0_var(--color-primary)]"
        >
          <h2 class="mb-5">Informations recette</h2>

          <div class="grid gap-5 md:grid-cols-2">
            <div class="md:col-span-2">
              <label class="label" for="titre">Titre</label>
              <input
                id="titre"
                name="titre"
                class="input mt-2"
                required
                data-persist="true"
              />
              {
                createRecetteInputError?.fields.titre?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {createRecetteInputError.fields.titre[0]}
                  </p>
                )
              }
            </div>

            <div>
              <label class="label" for="categorie">Categorie</label>
              <select
                id="categorie"
                name="categorie"
                class="input mt-2 cursor-pointer"
                required
                data-persist="true"
              >
                <option value="Entrée">Entrée</option>
                <option value="Plat">Plat</option>
                <option value="Dessert">Dessert</option>
                <option value="Boisson">Boisson</option>
              </select>
              {
                createRecetteInputError?.fields.categorie?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {createRecetteInputError.fields.categorie[0]}
                  </p>
                )
              }
            </div>

            <div>
              <label class="label" for="objectif_sante">Objectif sante</label>
              <select
                id="objectif_sante"
                name="objectif_sante"
                class="input mt-2 cursor-pointer"
                required
                data-persist="true"
              >
                <option value="Prise de masse">Prise de masse</option>
                <option value="Perte de poids">Perte de poids</option>
                <option value="Équilibre">Équilibre</option>
              </select>
              {
                createRecetteInputError?.fields.objectif_sante?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {createRecetteInputError.fields.objectif_sante[0]}
                  </p>
                )
              }
            </div>

            <div class="md:col-span-2">
              <p class="label">Regimes</p>
              <div class="mt-3 grid gap-3 sm:grid-cols-2">
                {
                  regimeOptions.map((regime) => (
                    <label class="inline-flex items-center gap-2 text-sm font-afacad uppercase cursor-pointer">
                      <input
                        type="checkbox"
                        name="regimes"
                        value={regime.id}
                        class="h-4 w-4 appearance-none rounded-sm border-2 border-primary bg-secondary checked:bg-primary cursor-pointer"
                        data-persist="true"
                      />
                      {regime.name}
                    </label>
                  ))
                }
              </div>
              {
                createRecetteInputError?.fields.regimes?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {createRecetteInputError.fields.regimes[0]}
                  </p>
                )
              }
            </div>

            <div>
              <label class="label" for="temps_total">Temps total (min)</label>
              <input
                id="temps_total"
                name="temps_total"
                type="number"
                min="1"
                value="30"
                class="input mt-2"
                required
                data-persist="true"
              />
              {
                createRecetteInputError?.fields.temps_total?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {createRecetteInputError.fields.temps_total[0]}
                  </p>
                )
              }
            </div>

            <div>
              <label class="label" for="portions">Portions</label>
              <input
                id="portions"
                name="portions"
                type="number"
                min="1"
                value="2"
                class="input mt-2"
                required
                data-persist="true"
              />
              {
                createRecetteInputError?.fields.portions?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {createRecetteInputError.fields.portions[0]}
                  </p>
                )
              }
            </div>

            <div>
              <label class="label" for="kcal_portion">Kcal / portion</label>
              <input
                id="kcal_portion"
                name="kcal_portion"
                type="number"
                min="0"
                step="0.1"
                value="0"
                class="input mt-2"
                required
                data-persist="true"
              />
              {
                createRecetteInputError?.fields.kcal_portion?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {createRecetteInputError.fields.kcal_portion[0]}
                  </p>
                )
              }
            </div>

            <div>
              <label class="label" for="total_proteines"
                >Total proteines (g)</label
              >
              <input
                id="total_proteines"
                name="total_proteines"
                type="number"
                min="0"
                step="0.1"
                value="0"
                class="input mt-2"
                required
                data-persist="true"
              />
              {
                createRecetteInputError?.fields.total_proteines?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {createRecetteInputError.fields.total_proteines[0]}
                  </p>
                )
              }
            </div>

            <div>
              <label class="label" for="total_glucides"
                >Total glucides (g)</label
              >
              <input
                id="total_glucides"
                name="total_glucides"
                type="number"
                min="0"
                step="0.1"
                value="0"
                class="input mt-2"
                required
                data-persist="true"
              />
              {
                createRecetteInputError?.fields.total_glucides?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {createRecetteInputError.fields.total_glucides[0]}
                  </p>
                )
              }
            </div>

            <div>
              <label class="label" for="total_lipides">Total lipides (g)</label>
              <input
                id="total_lipides"
                name="total_lipides"
                type="number"
                min="0"
                step="0.1"
                value="0"
                class="input mt-2"
                required
                data-persist="true"
              />
              {
                createRecetteInputError?.fields.total_lipides?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {createRecetteInputError.fields.total_lipides[0]}
                  </p>
                )
              }
            </div>

            <div>
              <label class="label" for="image">Image</label>
              <input
                id="image"
                type="file"
                name="image"
                class="mt-2 block w-full rounded-2xl border-2 border-primary bg-secondary px-4 py-3 text-sm text-primary cursor-pointer"
                accept="image/*"
                required
              />
              <p class="mt-2 text-xs text-primary/80">Taille maximale: 5 Mo.</p>
              {
                createRecetteInputError?.fields.image?.[0] && (
                  <p class="mt-2 text-sm font-bold text-accent2">
                    {createRecetteInputError.fields.image[0]}
                  </p>
                )
              }
            </div>

            <div class="md:col-span-2">
              <label class="label" for="description">Description</label>
              <textarea
                id="description"
                name="description"
                class="mt-2 w-full rounded-2xl border-2 border-primary bg-secondary px-4 py-3 text-primary outline-none"
                rows={6}
                data-persist="true"></textarea>
            </div>
          </div>
        </article>

        {
          (createRecetteInputError?.fields.compositionJson?.[0] ||
            createRecetteInputError?.fields.etapesJson?.[0]) && (
            <p class="rounded-xl border-2 border-accent2 bg-accent2/10 px-4 py-3 text-sm font-bold text-accent2">
              {createRecetteInputError?.fields.compositionJson?.[0] ??
                createRecetteInputError?.fields.etapesJson?.[0]}
            </p>
          )
        }

        <RecetteEditIngredientsEtapes
          client:load
          ingredients={ingredientsLite}
          initialComposition={[]}
          initialEtapes={[]}
          compositionInputId="compositionJson"
          etapesInputId="etapesJson"
        />

        <div class="flex items-center justify-between gap-3">
          <a href="/profil" class="btn-outline">Annuler</a>
          <button type="submit" class="btn">Créer la recette</button>
        </div>
      </form>
    </div>
  </section>
</ProtectedLayout>

<script is:inline>
  (() => {
    const storageKey = "slurpy:recette:add:draft";
    const maxImageSizeBytes = 5 * 1024 * 1024;
    const maxImageSizeMessage = "L'image est trop lourde (max 5 Mo).";
    const form = document.getElementById("add-recette-form");
    const imageInput = document.getElementById("image");

    if (!(form instanceof HTMLFormElement)) return;

    const validateImageSize = () => {
      if (!(imageInput instanceof HTMLInputElement)) {
        return true;
      }

      const selectedFile = imageInput.files?.[0];

      if (!selectedFile) {
        imageInput.setCustomValidity("");
        return true;
      }

      const isValidSize = selectedFile.size <= maxImageSizeBytes;
      imageInput.setCustomValidity(isValidSize ? "" : maxImageSizeMessage);
      return isValidSize;
    };

    if (imageInput instanceof HTMLInputElement) {
      imageInput.addEventListener("change", () => {
        validateImageSize();
        imageInput.reportValidity();
      });
    }

    const shouldRestoreDraft = form.dataset.hasError === "true";
    const fields = Array.from(form.querySelectorAll("[data-persist='true']"));

    if (!shouldRestoreDraft) {
      sessionStorage.removeItem(storageKey);
    }

    let draft = {};
    try {
      draft = JSON.parse(sessionStorage.getItem(storageKey) ?? "{}");
    } catch {
      draft = {};
    }

    if (shouldRestoreDraft) {
      for (const field of fields) {
        if (
          !(field instanceof HTMLInputElement) &&
          !(field instanceof HTMLTextAreaElement) &&
          !(field instanceof HTMLSelectElement)
        ) {
          continue;
        }

        const fieldName = field.getAttribute("name");
        if (!fieldName) continue;

        if (field instanceof HTMLInputElement && field.type === "file") {
          continue;
        }

        const draftValue = draft[fieldName];

        if (field instanceof HTMLInputElement && field.type === "checkbox") {
          if (Array.isArray(draftValue)) {
            field.checked = draftValue.includes(field.value);
          }
          continue;
        }

        if (typeof draftValue === "string") {
          field.value = draftValue;
        }
      }
    }

    const saveDraft = () => {
      const nextDraft = {};

      for (const field of fields) {
        if (
          !(field instanceof HTMLInputElement) &&
          !(field instanceof HTMLTextAreaElement) &&
          !(field instanceof HTMLSelectElement)
        ) {
          continue;
        }

        const fieldName = field.getAttribute("name");
        if (!fieldName) continue;

        if (field instanceof HTMLInputElement && field.type === "file") {
          continue;
        }

        if (field instanceof HTMLInputElement && field.type === "checkbox") {
          if (!Array.isArray(nextDraft[fieldName])) {
            nextDraft[fieldName] = [];
          }

          if (field.checked) {
            nextDraft[fieldName].push(field.value);
          }
          continue;
        }

        nextDraft[fieldName] = field.value;
      }

      sessionStorage.setItem(storageKey, JSON.stringify(nextDraft));
    };

    for (const field of fields) {
      field.addEventListener("input", saveDraft);
      field.addEventListener("change", saveDraft);
    }

    form.addEventListener("submit", (event) => {
      if (!validateImageSize()) {
        event.preventDefault();
        if (imageInput instanceof HTMLInputElement) {
          imageInput.reportValidity();
        }
        return;
      }

      saveDraft();
    });
  })();
</script>
