---
import Layout from "../layouts/Layout.astro"
import DamierHero from "../components/ui/DamierHero.astro"
import CTABanner from "../components/ui/CTABanner.astro";
---
<Layout title="Contactez-nous - Slurpy"
    description="Contactez-nous pour toute question ou suggestion concernant Slurpy, votre compagnon de nutrition et de recettes personnalisé. Nous sommes là pour vous aider à atteindre vos objectifs alimentaires avec plaisir et efficacité."
    keywords="contact, support, questions, suggestions, aide, assistance, feedback, contactez-nous, slurpy support"
    ogImage="/og-image-contact.png"
    ogType="website"
>
    <main>
        <section class="p-0">
            <header>
                <DamierHero title="Contactez-nous" />
            </header>
            <div class="px-6 md:px-10 lg:px-14 flex items-center justify-center pt-10 md:pt-14 lg:pt-16 xl:pt-20 pb-12 md:pb-16 lg:pb-20 xl:pb-24">
                <div class="w-full max-w-7xl rounded-4xl border-3 border-primary bg-secondary px-4 sm:px-5 md:px-10 lg:px-14 xl:px-20 py-6 md:py-10 lg:py-12 pb-7 md:pb-10 lg:pb-12">
                    <h2 class="text-center m-0 mb-6 md:mb-8 lg:mb-10 leading-none">Des questions ?</h2>
                    <form class="w-full max-w-230 mx-auto grid gap-4 md:gap-5" action="" method="post">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-5">
                            <div class="flex flex-col gap-2 lg:gap-4">
                                <label class="label" for="firstName">Prénom</label>
                                <input class="input" type="text" id="firstName" name="firstName" required placeholder="Ex : Jean" />
                            </div>
                            <div class="flex flex-col gap-2 lg:gap-4">
                                <label class="label" for="name">Nom</label>
                                <input class="input" type="text" id="name" name="name" required placeholder="Ex : Dupont" />
                            </div>
                        </div>
                        <div class="flex flex-col gap-2 lg:gap-4">
                            <label class="label" for="email">Email</label>
                            <input class="input" type="email" id="email" name="email" required placeholder="Votre email..." />
                        </div>
                        <div class="flex flex-col gap-2 lg:gap-4">
                            <label class="label" for="subject">Sujet</label>
                            <input class="input" type="text" id="subject" name="subject" required placeholder="Votre sujet..." />
                        </div>
                        
                        <div class="flex flex-col gap-2 lg:gap-4">
                            <label class="label" for="message">Message</label>
                            <textarea class="w-full border-2 border-primary bg-secondary text-primary rounded-2xl shadow-[0_4px_0_0_var(--color-primary)] px-4 md:px-[1.15rem] pt-4 pb-3 outline-none text-sm md:text-base transition-all duration-200 placeholder:text-primary/60 min-h-40 md:min-h-52 xl:min-h-64 resize-y focus:translate-y-px focus:shadow-[0_3px_0_0_var(--color-primary)]";
 id="message" name="message" required placeholder="Votre message..."></textarea>
                        </div>
                        <button type="submit" class="w-full border-2 border-primary rounded-full bg-primary text-secondary font-afacad font-bold text-base md:text-lg leading-none px-5 py-3 md:py-4 shadow-[0_4px_0_0_color-mix(in_srgb,var(--color-primary)_75%,black_25%)] cursor-pointer mt-2 transition-all duration-200 hover:translate-y-px hover:shadow-[0_3px_0_0_color-mix(in_srgb,var(--color-primary)_75%,black_25%)] active:translate-y-0.5 active:shadow-[0_2px_0_0_color-mix(in_srgb,var(--color-primary)_75%,black_25%)]">Envoyer</button>
                    </form>
                </div>
            </div>
        </section>
        <CTABanner />
    </main>
</Layout>
