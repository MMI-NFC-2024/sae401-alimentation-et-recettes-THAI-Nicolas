---
import Layout from "../../layouts/Layout.astro";
import DamierHero from "../../components/ui/DamierHero.astro";
import CardArticle from "../../components/ui/CardArticle.astro";
import ArticlesSearchPagination from "../../components/ui/ArticlesSearchPagination.vue";

// Charge la liste complete des articles pour la grille et la recherche côté client.
import { getAllArticles } from "../../lib/services/articles.service";
const { data: articles, error: articlesError } = await getAllArticles(Astro.locals.pb);

---

<Layout title="Nos conseils et fiches - Slurpy"
    description="Découvrez nos conseils nutritionnels et fiches aliments pour atteindre vos objectifs alimentaires avec plaisir."
    keywords="conseils nutritionnels, fiches aliments, nutrition sportive, perte de poids, prise de masse, alimentation équilibrée, slurpy conseils, slurpy fiches"
    ogImage="/og-image-articles.png"
    ogType="website"
    >
    <main>
        <section class="p-0">
            <header>
                <DamierHero title="Nos conseils et fiches" />
            </header>
            <div class="section content-container">
                <ArticlesSearchPagination client:load />
                <div>
                    {articles.length > 0 ? (
                        <ul class="ul-grid">
                            {articles.map((article) => (
                                <li data-article-item data-type={article.type} data-title={article.titre}>
                                    <CardArticle article={article} />
                                </li>
                            ))}
                        </ul>

                        <div id="articles-pagination" data-pagination class="mt-10 flex justify-center"></div>

                        <p id="articles-empty" class="mt-8 text-center" hidden></p>
                    ): (
                        <p class="mt-8 text-center">
                            {articlesError ? "Les conseils sont temporairement indisponibles. Reessaie dans quelques instants." : "Aucun article trouve pour le moment."}
                        </p>
                    )
                }
                </div>
            </div>
        </section>
    </main>
</Layout>