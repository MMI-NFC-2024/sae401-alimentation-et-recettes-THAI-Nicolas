---
interface Props {
  variant?: 'primary' | 'secondary';
  size?: 'default' | 'header';
  href?: string;
  ariaLabel?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
}

const {
  variant = 'primary',
  size = 'default',
  href,
  ariaLabel,
  type = 'button',
  disabled = false,
} = Astro.props as Props;

const variantClass = variant === 'primary' ? 'bg-primary text-secondary' : 'bg-secondary text-primary';
const sizeClass =
  size === 'header'
    ? 'w-14 h-14 md:w-16 md:h-16 lg:w-16 lg:h-16 text-xl md:text-2xl'
    : 'w-14 h-14 md:w-16 md:h-16 lg:w-20 lg:h-20 text-xl md:text-2xl lg:text-3xl';
const circleClass = `inline-flex items-center justify-center rounded-full border-2 border-primary font-barlow leading-none overflow-hidden shadow-[0_4px_0_0_color-mix(in_srgb,var(--color-primary)_75%,black_25%)] transition-all duration-200 hover:translate-y-px hover:shadow-[0_3px_0_0_color-mix(in_srgb,var(--color-primary)_75%,black_25%)] active:translate-y-0.5 active:shadow-[0_2px_0_0_color-mix(in_srgb,var(--color-primary)_75%,black_25%)] disabled:opacity-60 disabled:cursor-not-allowed ${sizeClass} ${variantClass}`;
---

{href ? (
  <a
    href={href}
    aria-label={ariaLabel}
    class={circleClass}
  >
    <slot />
  </a>
) : (
  <button
    type={type}
    aria-label={ariaLabel}
    disabled={disabled}
    class={circleClass}
  >
    <slot />
  </button>
)}
