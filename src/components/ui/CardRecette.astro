---
import type { RecettesResponse } from "../../pocketbase-types";
import ImgPB from "./ImgPB.astro";

interface Props {
    recette: RecettesResponse;
    rating?: number;
    reviewsCount?: number;
}

const { recette, rating = 0, reviewsCount = 0 } = Astro.props as Readonly<Props>;
const title = recette.titre ?? 'Recette';
const href = `/recettes/${recette.slug ?? recette.id}`;
const authorRecord = (recette.expand as { user?: { id?: string; name?: string } } | undefined)?.user;
const auteur = authorRecord?.name ?? 'Anonyme';
const authorId = authorRecord?.id ?? recette.user;
const authorHref = authorId ? `/profil/${authorId}` : undefined;
const objectifSante = recette.objectif_sante ?? 'N/A';
const tempsTotal = recette.temps_total ?? 'N/A';
const timeLabel = typeof tempsTotal === 'number' ? `${tempsTotal} min` : `${tempsTotal}`;
const roundedRating = Math.max(0, Math.min(5, Math.round(Number(rating) || 0)));
const safeReviewsCount = Math.max(0, Number(reviewsCount) || 0);
---

<article class="group h-full w-full max-w-sm mx-auto rounded-2xl border-2 border-primary bg-secondary p-3 shadow-[0_4px_0_0_var(--color-primary)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_7px_0_0_var(--color-primary)]">
    <a href={href} class="block">
        <div class="mb-3 w-full">
            <ImgPB
                record={recette}
                image={recette.image}
                alt={`Image de la recette ${title}`}
                thumb="800x500"
                classPicture="w-full aspect-[3/2] overflow-hidden rounded-xl"
                classImg="w-full h-full object-cover transition-transform duration-300 group-hover:scale-103"
            />
        </div>
        <div class="flex items-start justify-between gap-3">
            <h3 class="font-barlow text-primary uppercase text-xl">{title}</h3>
            <span class="shrink-0 pt-1 text-sm font-bold text-primary">{timeLabel}</span>
        </div>
    </a>

    <p class="mt-1 text-left text-primary/90">
        de
        {authorHref ? (
            <a href={authorHref} class="ml-1 underline underline-offset-2 hover:text-accent2 transition-colors">
                {auteur}
            </a>
        ) : (
            <span class="ml-1 underline underline-offset-2">{auteur}</span>
        )}
    </p>

    <a href={href} class="mt-3 block">
        <div class="flex items-center justify-between gap-3">
            <div class="flex items-center gap-1">
                {Array.from({ length: 5 }).map((_, index) => (
                    <span class:list={["text-lg leading-none", index < roundedRating ? "text-primary" : "text-primary/30"]}>★</span>
                ))}
                <span class="ml-1 text-sm text-primary/80">({safeReviewsCount})</span>
            </div>

            <span class="rounded-md bg-primary px-3 py-1 text-xs font-bold uppercase tracking-wide text-secondary">{objectifSante}</span>
        </div>
    </a>
</article>