---
import type { RecettesResponse } from "../../pocketbase-types";
import ImgPB from "./ImgPB.astro";

interface Props {
    recette: RecettesResponse;
}

const { recette } = Astro.props as Readonly<Props>;
const title = recette.titre ?? 'Recette';
const href = `/recettes/${recette.slug ?? recette.id}`;
const auteur = recette.expand?.user?.name ?? 'Anonyme';
const difficulte = recette.difficulte ?? 'N/A';
const tempsTotal = recette.temps_total ?? 'N/A';
const timeLabel = typeof tempsTotal === 'number' ? `${tempsTotal} min` : `${tempsTotal}`;
const rating = 4;
const reviewsCount = 550;
---

<a href={href} class="group block w-full max-w-sm mx-auto">
    <article class="h-full rounded-2xl border-2 border-primary bg-secondary p-3 shadow-[0_4px_0_0_var(--color-primary)] transition-all duration-300 group-hover:-translate-y-0.5 group-hover:shadow-[0_7px_0_0_var(--color-primary)]">
        <div class="mb-3 w-full">
            <ImgPB
                record={recette}
                image={recette.image}
                alt={`Image de la recette ${title}`}
                thumb="800x500"
                classPicture="w-full aspect-[3/2] overflow-hidden rounded-xl"
                classImg="w-full h-full object-cover transition-transform duration-300 group-hover:scale-103"
            />
        </div>
        <div class="flex items-start justify-between gap-3">
            <h3 class="font-barlow text-primary uppercase text-xl">{title}</h3>
            <span class="shrink-0 pt-1 text-sm font-bold text-primary">{timeLabel}</span>
        </div>

        <p class="mt-1 text-left text-primary/90">de <span class="underline underline-offset-2">{auteur}</span></p>

        <div class="mt-3 flex items-center justify-between gap-3">
            <div class="flex items-center gap-1">
                {Array.from({ length: 5 }).map((_, index) => (
                    <span class:list={["text-lg leading-none", index < rating ? "text-primary" : "text-primary/30"]}>★</span>
                ))}
                <span class="ml-1 text-sm text-primary/80">(+{reviewsCount})</span>
            </div>

            <span class="rounded-md bg-primary px-3 py-1 text-xs font-bold uppercase tracking-wide text-secondary">{difficulte}</span>
        </div>
    </article>
</a>